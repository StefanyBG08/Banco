<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<StackPane prefHeight="400.0" prefWidth="400.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.banco1.HelloController">
    <children>

        <VBox fx:id="panelLogin" alignment="CENTER" spacing="15.0">
            <padding>
                <Insets bottom="30.0" left="50.0" right="50.0" top="30.0" />
            </padding>
            <children>
                <Label text="Iniciar sesion">
                    <font>
                        <Font name="System Bold" size="24.0" />
                    </font>
                </Label>
                <TextField fx:id="txtUsuario" promptText="Usuario" />
                <PasswordField fx:id="txtPassword" promptText="Contraseña" />
                <Button mnemonicParsing="false" onAction="#onLoginClick" prefWidth="120.0" style="-fx-cursor: hand;" text="Ingresar" />
                <Label fx:id="lblMensajeLogin" textFill="#e74c3c" />
            </children>
        </VBox>

        <VBox fx:id="panelBanco" alignment="CENTER" spacing="20.0">
            <padding>
                <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
            </padding>
            <children>
                <Label text="Bienvenido a tu banco">
                    <font>
                        <Font name="System Bold" size="20.0" />
                    </font>
                </Label>

                <Label fx:id="lblSaldo" text="Saldo actual: $0.00" textFill="#2c3e50">
                    <font>
                        <Font size="16.0" />
                    </font>
                </Label>

                <TextField fx:id="txtMonto" alignment="CENTER" maxWidth="200.0" promptText="Ingresa el monto aquí" />

                <HBox alignment="CENTER" spacing="15.0">
                    <children>
                        <Button mnemonicParsing="false" onAction="#onDepositarClick" prefWidth="120.0" style="-fx-cursor: hand;" text="Depositar" />
                        <Button mnemonicParsing="false" onAction="#onRetirarClick" prefWidth="120.0" style="-fx-cursor: hand;" text="Retirar" />
                    </children>
                </HBox>

                <HBox alignment="CENTER" spacing="15.0">
                    <children>
                        <Button mnemonicParsing="false" onAction="#onConsultarClick" prefWidth="120.0" style="-fx-cursor: hand;" text="Consultar Saldo" />
                        <Button mnemonicParsing="false" onAction="#onSalirClick" prefWidth="120.0" style="-fx-cursor: hand;" text="Salir" />
                    </children>
                </HBox>

                <Label fx:id="lblMensajeBanco" />
            </children>
        </VBox>

    </children>
</StackPane>
