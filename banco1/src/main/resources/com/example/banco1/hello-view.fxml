<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="15" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.banco1.HelloController">

    <!-- PANEL LOGIN -->
    <VBox fx:id="panelLogin" alignment="CENTER" spacing="10">
        <Label prefHeight="58.0" prefWidth="149.0" text="Banco Nacional Camaronas" />

        <TextField fx:id="txtUsuario" prefHeight="22.0" prefWidth="151.0" promptText="Usuario" />
        <PasswordField fx:id="txtPassword" promptText="Contraseña" />

        <Button onAction="#onLoginClick" text="Iniciar sesión" />

        <Label fx:id="lblMensajeLogin" style="-fx-text-fill: red;" />
    </VBox>

    <!-- PANEL BANCO -->
    <VBox fx:id="panelBanco" alignment="CENTER" spacing="10">

        <Label text="SISTEMA BANCARIO" />

        <Label fx:id="lblSaldo" text="Saldo actual: $0.00" />

        <TextField fx:id="txtMonto" promptText="Ingresa monto" />

        <HBox alignment="CENTER" spacing="10">
            <Button onAction="#onDepositarClick" text="Depositar" />
            <Button onAction="#onRetirarClick" text="Retirar" />
        </HBox>

        <Button onAction="#onConsultarClick" text="Consultar saldo" />

        <Button onAction="#onSalirClick" text="Salir" />

        <Label fx:id="lblMensajeBanco" />
    </VBox>

</VBox>
